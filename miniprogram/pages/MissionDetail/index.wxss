.mission-info_title {
  margin-bottom: 10px;
  font-size: medium;
}

.mission-info_desc {
  font-size: small;
  color: darkgray;
}

.mission-info_credit {
  font-size: small;
  color: darkgray;
  margin-left: 10px;
}

/* === 订单视图样式 === */
.status-completed {
  display: inline-block;
  padding: 6rpx 24rpx;
  background-color: #d4f8d4;
  color: #2d8a2d;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.status-pending {
  display: inline-block;
  padding: 6rpx 24rpx;
  background-color: #fff5f7;
  color: #ff99aa;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.dish-list {
  margin-top: 12rpx;
  padding: 16rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
}

.dish-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #eee;
}
.dish-item:last-child {
  border-bottom: none;
}

.dish-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.dish-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex: 1;
}

.dish-credit {
  font-size: 28rpx;
  color: #ff99aa;
  font-weight: bold;
}

.dish-meta {
  margin-top: 4rpx;
}

.dish-category {
  font-size: 22rpx;
  color: #999;
}

.dish-desc {
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}

.finish-btn {
  background-color: #ff99aa;
  color: white;
  border-radius: 40rpx;
  font-size: 30rpx;
  margin-top: 16rpx;
}