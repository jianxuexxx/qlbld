.container {
  padding: 20px;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.form-group {
  margin-bottom: 20px;
}

.form-group_label {
  font-weight: bold;
  margin-bottom: 8px;
  display: block;
  color: #333;
}

.form-control {
  width: 100%;
  padding: 12px;
  border: 1px solid #ddd;
  border-radius: 4px;
  box-sizing: border-box;
  background-color: white;
}

.textarea {
  min-height: 100px;
  height: auto;
}

.slider-container {
  background-color: white;
  padding: 15px;
  border-radius: 4px;
}

.slider-value {
  text-align: center;
  margin-top: 10px;
  font-weight: bold;
  color: #ff6b6b;
}

.btn-submit {
  width: 100%;
  background-color: #ff99aa;
  color: white;
  border: none;
  border-radius: 4px;
  padding: 15px;
  font-size: 16px;
  margin-top: 20px;
}

.btn-submit:hover {
  background-color: #ff7c90;
}